{
	"name": "strateegia-mcp",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"dev": "wrangler dev",
		"deploy": "wrangler deploy",
		"type-check": "tsc --noEmit",
		"cf-typegen": "wrangler types",
		"mcpb:install": "cd mcpb/server && npm install --omit=dev --no-audit --no-fund",
		"mcpb:pack": "npm run mcpb:install && npx --yes @anthropic-ai/mcpb pack mcpb strateegia.mcpb"
	},
	"dependencies": {
		"agents": "^0.9.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260408.1",
		"typescript": "6.0.2",
		"wrangler": "^4.79.0"
	}
}
